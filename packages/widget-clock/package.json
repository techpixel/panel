{
	"name": "@panel/widget-clock",
	"version": "0.1.0",
	"private": true,
	"description": "Live time widget for Panel.",
	"type": "module",
	"main": "./src/index.ts",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./Clock.svelte": "./src/Clock.svelte",
		"./package.json": "./package.json"
	},
	"keywords": ["panel-plugin", "panel-widget"],
	"panel": {
		"type": "widget"
	},
	"dependencies": {
		"@panel/plugin-sdk": "workspace:*",
		"@panel/runtime": "workspace:*"
	},
	"peerDependencies": {
		"svelte": ">=5"
	}
}
