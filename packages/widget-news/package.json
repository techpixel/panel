{
	"name": "@panel/widget-news",
	"version": "0.1.0",
	"private": true,
	"description": "News headlines widget for Panel.",
	"type": "module",
	"main": "./src/index.ts",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./News.svelte": "./src/News.svelte",
