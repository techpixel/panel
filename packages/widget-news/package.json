	},
	"keywords": ["panel-plugin", "panel-widget", "news"],
	"panel": {
		"type": "widget"
	},
	"dependencies": {
		"@panel/plugin-sdk": "workspace:*",
		"lucide-svelte": "^0.563.0"
	},
