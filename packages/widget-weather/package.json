{
	"name": "@panel/widget-weather",
	"version": "0.1.0",
	"private": true,
	"description": "Weather widget with condition-aware gradient backgrounds.",
	"type": "module",
	"main": "./src/index.ts",
	"svelte": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"svelte": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./Weather.svelte": "./src/Weather.svelte",
		"./gradients": "./src/gradients.ts",
		"./icons": "./src/icons.ts",
		"./package.json": "./package.json"
	},
	"keywords": ["panel-plugin", "panel-widget", "weather"],
	"panel": {
		"type": "widget"
	},
	"dependencies": {
		"@panel/plugin-sdk": "workspace:*",
		"@panel/runtime": "workspace:*",
		"lucide-svelte": "^0.563.0"
	},
	"peerDependencies": {
		"svelte": ">=5"
	}
